{
  "expo": {
    "name": "Rentory",
    "slug": "rentory-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "rentory",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "backgroundColor": "#0f766e",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.rentory.mobile"
    },
    "android": {
      "package": "app.rentory.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0f766e"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
